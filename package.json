{
  "name": "movie-catalog-api",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:back\"",
    "dev:front": "cd frontend && npm run dev",
    "dev:back": "cd backend && npm run start:dev",
    "build": "npm run build:front && npm run build:back",
    "build:front": "cd frontend && npm run build",
    "build:back": "cd backend && npm run build"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0"
  }
}
